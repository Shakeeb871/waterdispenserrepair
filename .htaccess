# =====================================================================
# Water Dispenser Repair — Apache configuration for cPanel shared hosting
# =====================================================================

# ----- Default document -----
DirectoryIndex index.html index.php

# ----- Canonical domain: force HTTPS + non-www (preferred version) -----
# A single 301 sends http->https AND www->non-www to one preferred host
# (https://waterdispenserrepair.ae/), matching the rel="canonical" tags so
# search engines index ONE version only and link equity is never split.
# Requires an SSL certificate — cPanel AutoSSL installs one automatically.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\. [NC]
  RewriteRule ^ https://waterdispenserrepair.ae%{REQUEST_URI} [R=301,L]
</IfModule>

# ----- Custom error pages -----
ErrorDocument 404 /404.html

# ----- SEO-friendly clean URLs (extensionless, trailing slash) -----
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect any index / index.html (root OR sub-folder) to its clean dir
  #   /index.html               -> /
  #   /brands/philips/index.html -> /brands/philips/
  RewriteCond %{THE_REQUEST} \s/+(.+/)?index(\.html)?[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # 301: .html  ->  clean URL with trailing slash
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # 301: .php  ->  clean URL with trailing slash
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.php[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # 301: flat brand-xxx  ->  canonical /brands/xxx/
  RewriteCond %{THE_REQUEST} \s/+brand-([a-z0-9-]+)[\s?] [NC]
  RewriteRule ^ /brands/%1/ [R=301,L]

  # 301: enforce trailing slash on extensionless URLs (skip real files/dirs)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]+)$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ /$1/ [R=301,L]

  # /locations/ has no listing page -> send to the homepage hub
  RewriteRule ^locations/?$ / [R=301,L]

  # Serve the brands listing page:  /brands/  ->  brands/index.html
  RewriteRule ^brands/?$ brands/index.html [L]

  # Serve brand pages:  /brands/philips/  ->  brands/philips/index.html
  RewriteRule ^brands/([a-z0-9-]+)/?$ brands/$1/index.html [L]

  # Serve location pages:  /water-dispenser-repair-sharjah/  ->  locations/water-dispenser-repair-sharjah.html
  RewriteRule ^water-dispenser-repair-([a-z-]+)/?$ locations/water-dispenser-repair-$1.html [L]

  # Serve clean URLs internally: add .html, then .php, if the file exists
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^.]+?)/?$ $1.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.php -f
  RewriteRule ^([^.]+?)/?$ $1.php [L]
</IfModule>

# ----- Protect sensitive files -----
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|bak|env)$">
  Require all denied
</FilesMatch>

# Block direct access to the includes directory
RedirectMatch 403 ^/includes/.*$

# ----- Disable directory browsing -----
Options -Indexes

# ----- Security headers -----
<IfModule mod_headers.c>
  # DEVELOPMENT PHASE: block all search engines from indexing.
  # ⚠️ TO GO LIVE: delete the next line (X-Robots-Tag) to allow indexing.
  Header set X-Robots-Tag "noindex, nofollow, noarchive"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — enforce HTTPS in browsers (only honoured on secure responses)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ----- GZIP compression -----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

# ----- Browser caching -----
# DEVELOPMENT PHASE: code/markup are NOT cached so every change shows instantly.
# ⚠️ TO GO LIVE (faster site): change the css/js/html lines below to longer times,
#    e.g. "access plus 1 week" for css/js and "access plus 1 day" for html.
<IfModule mod_expires.c>
  ExpiresActive On
  # Images can cache (logo/photos rarely change)
  ExpiresByType image/svg+xml          "access plus 1 week"
  ExpiresByType image/jpeg             "access plus 1 week"
  ExpiresByType image/png              "access plus 1 week"
  ExpiresByType image/webp             "access plus 1 week"
  # Code & markup — no caching during development
  ExpiresByType text/css               "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>

# Force browsers to re-fetch CSS/JS/HTML every time (development phase)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ----- Default charset -----
AddDefaultCharset UTF-8
